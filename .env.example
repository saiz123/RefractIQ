# Copy this file to .env and fill in your API keys.
# Never commit .env to git — it is in .gitignore.
# AgentForge reads keys from environment variables only.

# ── AI Provider Keys ──────────────────────────────────────────

# Anthropic (Claude Sonnet, Haiku, Opus)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, GPT-4o-mini, o4-mini)
OPENAI_API_KEY=

# Google Gemini (Gemini 1.5 Pro, Gemini 1.5 Flash)
GEMINI_API_KEY=

OPENROUTER_API_KEY=

# Custom OpenAI-compatible endpoint (e.g. Azure, local vLLM)
OPENAI_COMPATIBLE_ENDPOINT=
OPENAI_COMPATIBLE_API_KEY=

# Ollama — no key needed; override endpoint if non-default
OLLAMA_ENDPOINT=http://localhost:11434

# ── AgentForge Settings ───────────────────────────────────────

# Log level: silent | error | warn | info | debug
AGENTFORGE_LOG_LEVEL=info

# Default per-run budget in USD (overridable with --budget flag)
AGENTFORGE_DEFAULT_BUDGET_USD=0.50

# Optional: set to require bearer token authentication for the web API
# Recommended when exposing the API beyond localhost
AGENTFORGE_API_TOKEN=
