{
  "name": "@refractiq/cli",
  "version": "0.1.0",
  "description": "RefractIQ CLI — refractiq init, build, plan, doctor, report",
  "type": "module",
  "bin": {
    "refractiq": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/fix-shebang.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "node --watch dist/bin/cli.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@refractiq/context-engine": "workspace:*",
    "@refractiq/cost-engine": "workspace:*",
    "@refractiq/evaluator": "workspace:*",
    "@refractiq/model-router": "workspace:*",
    "@refractiq/orchestrator": "workspace:*",
    "@refractiq/providers": "workspace:*",
    "@refractiq/shared": "workspace:*",
    "@refractiq/token-engine": "workspace:*",
    "@refractiq/workspace-engine": "workspace:*",
    "@inquirer/prompts": "^7.0.0",
    "@libsql/client": "^0.14.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.33.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "drizzle-kit": "^0.24.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
